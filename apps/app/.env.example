# Vite dev-server proxy target for `/api/deepl/*`.
# Defaults to the Free tier (used when the var is unset).
# Pro users uncomment the second line.
DEEPL_API_TARGET=https://api-free.deepl.com
# DEEPL_API_TARGET=https://api.deepl.com

# Endpoint the in-app DeepL provider should call. In dev, point it at the
# proxy above; in a production deployment with your own proxy, point it at
# whatever same-origin URL the proxy exposes.
VITE_DEEPL_ENDPOINT=/api/deepl/v2/translate
