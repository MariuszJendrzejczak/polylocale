{
  "name": "polylocale",
  "private": true,
  "version": "0.0.0",
  "description": "Open-source, web-based localization manager for Flutter (and beyond). Pre-alpha.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @polylocale/app dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rimraf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.5",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
